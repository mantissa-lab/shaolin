require "spec_helper"

# Request spec — boots the app and hits HTTP. Needs a database (tagged :integration).
RSpec.describe "<%= @name %> requests", :integration do
  before(:all) { boot_app! }

  let(:session) { Rack::Test::Session.new(Shaolin::Kernel["http.app"]) }

  def json_post(path, payload)
    session.post(path, JSON.generate(payload), "CONTENT_TYPE" => "application/json")
  end

  it "creates, reads, updates, lists and deletes a <%= @entity_us %>" do
    json_post("/<%= @name %>", { name: "Example" })
    expect(session.last_response.status).to eq(201)
    location = session.last_response.headers["location"]

    session.get(location)
    expect(session.last_response.status).to eq(200)
    expect(JSON.parse(session.last_response.body)["name"]).to eq("Example")

    session.patch(location, JSON.generate(name: "Updated"), "CONTENT_TYPE" => "application/json")
    expect(session.last_response.status).to eq(200)
    expect(JSON.parse(session.last_response.body)["name"]).to eq("Updated")

    session.get("/<%= @name %>")
    expect(session.last_response.status).to eq(200)
    expect(JSON.parse(session.last_response.body)).to be_an(Array)

    session.delete(location)
    expect(session.last_response.status).to eq(204)

    session.get(location)
    expect(session.last_response.status).to eq(404)
  end
end
