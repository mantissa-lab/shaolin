require "shaolin/cqrs"

module <%= @ns %>
  module Projections
    class <%= @ns %>Projection < Shaolin::CQRS::Projection
      on(Events::<%= @event %>) do |event|
        ReadModels::<%= @entity %>Record.project(id: event.data[:id]) do |record|
          record.name = event.data[:name]
        end
      end
    end
  end
end
