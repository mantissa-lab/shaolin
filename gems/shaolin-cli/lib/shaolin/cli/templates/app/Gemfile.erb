source "https://rubygems.org"

# The whole shaolin framework in one gem — kernel, CQRS/ES, ActiveRecord, DTOs,
# HTTP, server, jobs/outbox, messaging, Redis, RabbitMQ, LLM, harness, and the
# `shaolin` CLI. `require "shaolin"` (config/boot.rb) loads it all.
gem "shaolin"

group :development, :test do
  gem "rspec", "~> 3.13"
  gem "rack-test"
end
