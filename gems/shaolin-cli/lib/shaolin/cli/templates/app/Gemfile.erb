source "https://rubygems.org"

# The whole shaolin framework in one gem — kernel, CQRS/ES, ActiveRecord, DTOs,
# HTTP, server, jobs/outbox, messaging, Redis, RabbitMQ, LLM, harness, and the
# `shaolin` CLI. `require "shaolin"` (config/boot.rb) loads it all.
#
# Installed from the public git repo (not RubyGems). `glob:` lets Bundler see
# every gemspec in the repo, so this single line resolves all sub-gems; `tag:`
# pins a release for reproducible builds (incl. Docker — public https needs no
# credentials). Bump the tag to upgrade. (Proprietary; see the repo LICENSE.)
gem "shaolin", git: "https://github.com/mantissa-lab/shaolin.git", tag: "v0.1.0", glob: "gems/*/*.gemspec"

group :development, :test do
  gem "rspec", "~> 3.13"
  gem "rack-test"
end
