require "shaolin/core"
require "shaolin/cqrs"
require "shaolin/activerecord"
require "shaolin/dto"
require "shaolin/http"

module <%= @app_class %>
  ROOT = File.expand_path("..", __dir__)

  DATABASE = {
    adapter: "postgresql",
    database: ENV.fetch("DB_NAME", "<%= @app %>_development"),
    username: ENV.fetch("DB_USER", "postgres"),
    host: ENV.fetch("DB_HOST", "localhost"),
    port: Integer(ENV.fetch("DB_PORT", "5432"))
  }.freeze

  PRODUCTION = ENV["SHAOLIN_ENV"] == "production"

  def self.boot!
    # In production set DB_POOL >= (web fibers / worker threads); schema is a
    # deliberate release step (`shaolin migrate`), so auto_schema stays off and
    # boots are cheap.
    Shaolin::AR.register_provider!(config: DATABASE, auto_schema: !PRODUCTION)
    Shaolin::CQRS.register_provider!
    # Swagger UI at /swagger (+ /openapi.json) in dev; off in production by default.
    Shaolin::HTTP.register_provider!(swagger: !PRODUCTION, modules_dir: File.join(ROOT, "app/modules"))
    app = Shaolin::App.new(root: ROOT).boot!
    # Read-model migrations: automatic in dev for a zero-step start; in production
    # run them explicitly via `shaolin migrate`, not on every pod boot.
    migrate! unless PRODUCTION
    app
  end

  def self.migrate!
    Shaolin::AR::EventStoreSchema.create!
    Shaolin::AR::Migrator.run(File.join(ROOT, "app/modules"))
  end
end

<%= @app_class %>.boot! unless ENV["SHAOLIN_SKIP_BOOT"]
