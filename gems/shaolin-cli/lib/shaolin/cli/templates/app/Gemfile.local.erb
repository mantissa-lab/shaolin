source "https://rubygems.org"

# shaolin framework (local path build — the gems are not published yet). The
# `glob:` option points Bundler at every gemspec in the checkout, so the single
# umbrella `gem "shaolin"` resolves all of its sub-gems straight from the path —
# no need to list each one. (A published consumer's Gemfile is just `gem
# "shaolin"`; a private build can use `git: "<repo>", glob: "gems/*/*.gemspec"`.)
gem "shaolin", path: "<%= @local_path %>", glob: "gems/*/*.gemspec"

group :development, :test do
  gem "rspec", "~> 3.13"
  gem "rack-test"
end
