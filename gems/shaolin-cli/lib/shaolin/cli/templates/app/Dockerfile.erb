# syntax=docker/dockerfile:1
FROM ruby:4.0-slim-bookworm AS build
# git: shaolin is bundled from its git repo (gem "shaolin", git: ...)
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
      build-essential libpq-dev git && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY Gemfile Gemfile.lock ./
RUN bundle config set --local without 'development test' && bundle install
COPY . .

FROM ruby:4.0-slim-bookworm AS runtime
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
      libpq5 && rm -rf /var/lib/apt/lists/* \
    && useradd --create-home --uid 1000 shaolin
WORKDIR /app
COPY --from=build /usr/local/bundle /usr/local/bundle
COPY --from=build /app /app
USER shaolin
ENV PORT=8080
EXPOSE 8080
ENTRYPOINT ["bundle", "exec", "ruby", "bin/server"]
